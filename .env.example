# ============================================================
# Ganesh Trading Company - Environment Variables
# Copy this file to ".env" and fill in the real values.
# ============================================================

# --- Database (PostgreSQL) ---
# Local example: postgresql://postgres:postgres@localhost:5432/ganesh?schema=public
# Production (e.g. Neon / Supabase / Railway): use the pooled connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ganesh?schema=public"

# --- Admin Authentication ---
# Secret used to sign the admin JWT session cookie. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-this-to-a-long-random-secret-string"

# Default admin account created by the seed script.
ADMIN_EMAIL="admin@ganeshtrading.com"
ADMIN_PASSWORD="Admin@12345"

# --- WhatsApp Business ---
# Country code + number, digits only (no +, no spaces). Example: 919999999999
WHATSAPP_NUMBER="919999999999"

# --- Cloudinary (Product Images) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Unsigned upload preset (create one in the Cloudinary dashboard).
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="ganesh_products"

# --- Public Site URL (for SEO / sitemap / Open Graph) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_NAME="Ganesh Trading Company"
NEXT_PUBLIC_BUSINESS_PHONE="+91 8104337239"
NEXT_PUBLIC_BUSINESS_ADDRESS="Varale Pune, Maharashtra, India"
# Google Maps share link for the shop (tap-to-open directions)
NEXT_PUBLIC_BUSINESS_MAP_URL="https://maps.app.goo.gl/your-shop-link"
